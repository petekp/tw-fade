# Dependencies
node_modules/

# Local tooling / editor state (not part of the package)
.circuit/
.claude/
.tmp/

# Logs & OS cruft
*.log
npm-debug.log*
.DS_Store

# Generated debug harness (maintainer-only dev tool, not shipped).
# Sources live in scripts/debug/; regenerate with `npm run debug`.
/debug/

# Note: dist/ and demo/styles.css ARE tracked on purpose — they're the
# shipped (npm) and served (demo) artifacts. They're regenerated by
# `npm run build` and `npm run build:demo`, and prepublishOnly rebuilds
# dist before every publish.
